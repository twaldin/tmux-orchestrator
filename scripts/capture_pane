#!/bin/bash
# capture_pane — Capture recent output from an agent's tmux pane
#
# Usage:
#   capture_pane <name>            # Last 50 lines (default)
#   capture_pane <name> <lines>    # Last N lines
#   capture_pane <name> all        # Full scrollback

SESSION="${TMUX_ORCHESTRATOR_SESSION:-$(tmux display-message -p '#{session_name}' 2>/dev/null)}"

NAME="$1"
LINES="${2:-50}"

if [ -z "$NAME" ]; then
  echo "Usage: capture_pane <name> [lines|all]"
  exit 1
fi

# tmux window name IS the agent name — no registry needed
if ! tmux list-windows -t "$SESSION" -F '#{window_name}' 2>/dev/null | grep -q "^${NAME}$"; then
  echo "ERROR: Agent '$NAME' not found in session '$SESSION'"
  exit 1
fi

if [ "$LINES" = "all" ]; then
  tmux capture-pane -t "$SESSION:$NAME" -p -S -
else
  tmux capture-pane -t "$SESSION:$NAME" -p -S "-$LINES"
fi
